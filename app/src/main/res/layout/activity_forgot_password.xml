<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fillViewport="true" android:background="@color/nb_primary_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">
        <ImageView android:layout_width="120dp" android:layout_height="80dp"
            android:src="@drawable/nearbuy_logo" android:contentDescription="@string/logo_desc"
            android:layout_marginTop="56dp" android:scaleType="fitCenter"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/forgot_title" android:textSize="26sp" android:textStyle="bold"
            android:textColor="@color/white" android:layout_marginTop="24dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/forgot_subtitle" android:textSize="14sp"
            android:textColor="@color/text_on_dark_secondary" android:gravity="center"
            android:lineSpacingMultiplier="1.4" android:layout_marginTop="10dp" android:layout_marginBottom="36dp"/>
        <EditText android:id="@+id/etEmail"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="@string/hint_reset_email" android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field" android:padding="16dp"
            android:textColor="@color/text_dark_primary" android:textColorHint="@color/text_dark_hint"
            android:layout_marginBottom="24dp"/>
        <Button android:id="@+id/btnSendReset"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="@string/btn_send_reset" android:textColor="@color/white"
            android:textSize="17sp" android:textStyle="bold"
            android:background="@drawable/btn_orange" android:elevation="4dp" android:layout_marginBottom="20dp"/>
        <TextView android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/back_to_login" android:textColor="@color/nb_accent_light"
            android:textSize="14sp" android:textStyle="bold" android:clickable="true" android:focusable="true"/>
    </LinearLayout>
</ScrollView>
