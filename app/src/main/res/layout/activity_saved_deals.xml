<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".Saved_Deals">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="@drawable/bg_icon_circle_white"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Saved Deals"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_deal_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 Deals"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_icon_circle_white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_total_saved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6"
                        android:textColor="#1B2D4F"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Saved"
                        android:textColor="#9AA0AC"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_expiring_soon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textColor="#F5A623"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expiring Soon"
                        android:textColor="#9AA0AC"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_white"
                    android:padding="10dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_total_savings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="රු485"
                        android:textColor="#27AE60"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You Save"
                        android:textColor="#9AA0AC"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <LinearLayout
                android:id="@+id/filter_tabs"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_active"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tab_food"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Food"
                    android:textColor="#9AA0AC"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tab_beverages"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Beverages"
                    android:textColor="#9AA0AC"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tab_household"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Household"
                    android:textColor="#9AA0AC"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_tab_inactive" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_saved_deals"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_saved_deal" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>