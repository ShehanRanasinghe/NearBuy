<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_light_grey">
    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@drawable/bg_topbar_curved"
        android:paddingStart="18dp" android:paddingEnd="18dp"
        android:paddingTop="16dp" android:paddingBottom="20dp" android:elevation="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Find Products Near You" android:textColor="@color/white"
            android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
        <!-- Search Bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_field" android:paddingStart="12dp" android:paddingEnd="12dp">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_search" app:tint="@color/text_dark_hint"/>
            <EditText android:id="@+id/etSearch"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:background="@null"
                android:hint="@string/search_hint" android:textSize="14sp"
                android:textColor="@color/text_dark_primary" android:textColorHint="@color/text_dark_hint"
                android:paddingStart="8dp" android:imeOptions="actionSearch"
                android:inputType="text" android:singleLine="true"/>
        </LinearLayout>
    </LinearLayout>
    <!-- Distance filter chips -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/bg_white"
        android:paddingStart="18dp" android:paddingEnd="18dp"
        android:paddingTop="12dp" android:paddingBottom="12dp" android:elevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/distance_label" android:textColor="@color/text_dark_secondary"
                android:textSize="13sp" android:textStyle="bold" android:layout_marginEnd="10dp"/>
            <HorizontalScrollView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:scrollbars="none">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/chip1km" android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="1 km" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/white" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/bg_distance_chip_active" android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chip2km" android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="2 km" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/nb_primary" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/bg_distance_chip" android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chip5km" android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="5 km" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/nb_primary" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/bg_distance_chip" android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chip10km" android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="10 km" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/nb_primary" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/bg_distance_chip"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
        <!-- Sort row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/sort_by" android:textColor="@color/text_dark_secondary"
                android:textSize="13sp" android:layout_marginEnd="10dp"/>
            <TextView android:id="@+id/sortDistance"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="@string/sort_distance" android:textSize="12sp" android:textStyle="bold"
                android:textColor="@color/white" android:gravity="center"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:background="@drawable/bg_distance_chip_active" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/sortPrice"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="@string/sort_price" android:textSize="12sp" android:textStyle="bold"
                android:textColor="@color/nb_primary" android:gravity="center"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:background="@drawable/bg_distance_chip"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>
    <!-- Results header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="18dp" android:paddingEnd="18dp"
        android:paddingTop="14dp" android:paddingBottom="6dp">
        <TextView android:id="@+id/tvResultCount"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="12 results found"
            android:textColor="@color/text_dark_secondary" android:textSize="13sp"/>
    </LinearLayout>
    <!-- Results List -->
    <ListView android:id="@+id/listSearchResults"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:divider="@null"
        android:paddingStart="18dp" android:paddingEnd="18dp"
        android:paddingBottom="12dp" android:clipToPadding="false"/>
</LinearLayout>
