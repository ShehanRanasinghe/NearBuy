<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_white"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:elevation="2dp"
    android:gravity="center_vertical">

    <!-- Emoji circle -->
    <LinearLayout
        android:id="@+id/ivEmojiCircle"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:gravity="center"
        android:background="@drawable/bg_icon_circle_teal"
        android:layout_marginEnd="14dp">
        <TextView
            android:id="@+id/tvItemEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛍"
            android:textSize="24sp"/>
    </LinearLayout>

    <!-- Middle info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvItemTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50% OFF Fresh Apples"
            android:textColor="@color/text_dark_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvItemShop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FreshMart Grocery"
            android:textColor="@color/text_dark_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvItemDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Farm fresh, limited time"
            android:textColor="@color/text_dark_hint"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Right: badge + validity -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvItemBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50% OFF"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_tab_active"/>

        <TextView
            android:id="@+id/tvItemValidity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 days left"
            android:textColor="@color/stat_red"
            android:textSize="10sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</LinearLayout>

