<?xml version="1.0" encoding="utf-8"?>
<!--
    item_deal_promo.xml
    Full-detail card used in DealsAndPromoActivity for both deals and promotions.
    Fields shown / hidden dynamically by DealPromoAdapter based on isPromotion flag.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_white"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:elevation="2dp"
    android:clickable="true"
    android:focusable="true">

    <!-- ── Row 1: Emoji circle + Title/Occasion + Discount badge ────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Emoji icon circle -->
        <LinearLayout
            android:id="@+id/ivEmojiCircle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:background="@drawable/bg_icon_circle_teal"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvItemEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍"
                android:textSize="22sp"/>
        </LinearLayout>

        <!-- Title + Occasion subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50% OFF Fresh Apples"
                android:textColor="@color/text_dark_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- Occasion — visible for promotions only -->
            <TextView
                android:id="@+id/tvItemOccasion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weekend Sale"
                android:textColor="@color/nb_primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Discount / promo badge -->
        <TextView
            android:id="@+id/tvItemBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50% OFF"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_tab_active"/>
    </LinearLayout>

    <!-- ── Thin divider ────────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"/>

    <!-- ── Row 2: Shop + Distance | Category chip | Validity ────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Shop name and distance -->
        <TextView
            android:id="@+id/tvItemShop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FreshMart Grocery · 0.8 km"
            android:textColor="@color/text_dark_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginEnd="8dp"/>

        <!-- Category chip — visible for promotions only -->
        <TextView
            android:id="@+id/tvItemCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒 Groceries"
            android:textColor="@color/nb_primary"
            android:textSize="10sp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/bg_distance_chip"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <!-- Validity / expiry label -->
        <TextView
            android:id="@+id/tvItemValidity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 days left"
            android:textColor="@color/stat_red"
            android:textSize="10sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Row 3: Description (full text) ─────────────────────────────────── -->
    <TextView
        android:id="@+id/tvItemDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Farm fresh, limited time offer"
        android:textColor="@color/text_dark_hint"
        android:textSize="11sp"
        android:layout_marginTop="6dp"
        android:maxLines="4"
        android:ellipsize="end"/>

    <!-- ── Row 4: Prices — visible only when prices exist ────────────────── -->
    <LinearLayout
        android:id="@+id/layoutItemPrices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <!-- Original price (strikethrough applied in adapter) -->
        <TextView
            android:id="@+id/tvItemOriginalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rs.500"
            android:textColor="@color/text_dark_hint"
            android:textSize="12sp"
            android:layout_marginEnd="6dp"/>

        <!-- Sale price -->
        <TextView
            android:id="@+id/tvItemSalePrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rs.350"
            android:textColor="@color/stat_green"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
