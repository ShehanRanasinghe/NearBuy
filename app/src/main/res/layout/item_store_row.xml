<?xml version="1.0" encoding="utf-8"?>
<!--
    item_store_row.xml
    Reusable row for products, deals and promotions inside StoreDetailsActivity.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_deal_item"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon circle -->
    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_chip_white"
        android:gravity="center"
        android:layout_marginEnd="12dp">
        <TextView
            android:id="@+id/tvRowEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒"
            android:textSize="22sp"/>
    </LinearLayout>

    <!-- Name + subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name"
            android:textColor="#1B2D4F"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvRowSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category  •  Rs. 0"
            android:textColor="#9AA0AC"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Badge (In Stock / OFF%) -->
    <TextView
        android:id="@+id/tvRowBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="In Stock"
        android:textColor="#27AE60"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"/>

</LinearLayout>

