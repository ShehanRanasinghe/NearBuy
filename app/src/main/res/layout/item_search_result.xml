<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/bg_search_result_card"
    android:padding="14dp" android:layout_marginBottom="10dp"
    android:elevation="2dp" android:clickable="true" android:focusable="true">
    <!-- Product image circle -->
    <LinearLayout android:layout_width="60dp" android:layout_height="60dp"
        android:gravity="center" android:background="@drawable/bg_icon_circle_teal">
        <TextView android:id="@+id/tvProductEmoji"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🍎" android:textSize="28sp"/>
    </LinearLayout>
    <!-- Product info -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvProductName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Fresh Red Apples" android:textColor="@color/text_dark_primary"
            android:textSize="15sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvShopName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FreshMart Grocery" android:textColor="@color/text_dark_secondary"
            android:textSize="12sp" android:layout_marginTop="2dp"/>
        <!-- Distance badge -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/bg_distance_badge"
                android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="3dp" android:paddingBottom="3dp"
                android:id="@+id/tvDistance" android:text="0.8 km"
                android:textColor="@color/nb_primary" android:textSize="11sp" android:textStyle="bold"
                android:layout_marginEnd="6dp"/>
            <TextView android:id="@+id/tvCategory"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Fruits" android:textColor="@color/text_dark_hint"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>
    <!-- Price column -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center_horizontal">
        <TextView android:id="@+id/tvPrice"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_price_badge"
            android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="5dp" android:paddingBottom="5dp"
            android:text="Rs.120" android:textColor="@color/white"
            android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvOriginalPrice"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Rs.200" android:textColor="@color/text_dark_hint"
            android:textSize="11sp" android:layout_marginTop="3dp"/>
    </LinearLayout>
</LinearLayout>
