<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light_grey">

    <!-- TOP HEADER BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_topbar_curved"
        android:paddingStart="16dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_icon_circle_white"
            android:padding="8dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Profile"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- AVATAR HERO SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_marginTop="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:layout_height="160dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card">

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:background="@drawable/bg_profile_avatar"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="38sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kamal Perera"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_user_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="@drawable/bg_status_badge"/>
            </LinearLayout>

            <!-- ACCOUNT INFO CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT INFO"
                    android:textColor="@color/text_dark_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="14dp"/>

                <!-- Full Name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_circle_teal"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="16sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full Name"
                            android:textColor="@color/text_dark_hint"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tv_full_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kamal Perera"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_light" android:layout_marginBottom="14dp"/>

                <!-- Email row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_circle_teal"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📧"
                            android:textSize="16sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textColor="@color/text_dark_hint"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tv_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="kamal.perera@gmail.com"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_light" android:layout_marginBottom="14dp"/>

                <!-- Contact Number row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_circle_orange"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📞"
                            android:textSize="16sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact Number"
                            android:textColor="@color/text_dark_hint"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tv_phone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+94 77 123 4567"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_light" android:layout_marginBottom="14dp"/>

                <!-- Location row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_circle_teal"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="16sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Location"
                            android:textColor="@color/text_dark_hint"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tv_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Colombo 03, Sri Lanka"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <!-- Change location button -->
                    <TextView
                        android:id="@+id/btn_change_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change"
                        android:textColor="@color/nb_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_chip_outline_teal"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- NEARBY SEARCH DISTANCE CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:elevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_circle_teal"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📡"
                            android:textSize="16sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEARBY SEARCH DISTANCE"
                            android:textColor="@color/text_dark_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tv_search_radius"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 km (default)"
                            android:textColor="@color/text_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shops and deals within this radius will be shown on your home screen."
                    android:textColor="@color/text_dark_hint"
                    android:textSize="11sp"
                    android:layout_marginBottom="14dp"/>

                <!-- Distance chip row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/chip_radius_1"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="1 km"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark_primary"
                        android:background="@drawable/bg_distance_chip"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chip_radius_2"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="2 km"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_distance_chip_active"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chip_radius_5"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="5 km"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark_primary"
                        android:background="@drawable/bg_distance_chip"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chip_radius_10"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="10 km"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark_primary"
                        android:background="@drawable/bg_distance_chip"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chip_radius_20"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="20 km"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark_primary"
                        android:background="@drawable/bg_distance_chip"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- EDIT PROFILE BUTTON -->
            <LinearLayout
                android:id="@+id/btn_edit_profile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_distance_chip_active"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️  "
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit Profile"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- LOGOUT BUTTON -->
            <LinearLayout
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_cancel_btn"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚪  "
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log Out"
                    android:textColor="#E03B2F"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav_bar"
        android:elevation="12dp"
        android:baselineAligned="false">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navHomeIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_home" app:tint="@color/text_dark_hint"/>
            <TextView android:id="@+id/navHomeText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textSize="10sp" android:textColor="@color/text_dark_hint"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navSearch"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navSearchIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_search" app:tint="@color/text_dark_hint"/>
            <TextView android:id="@+id/navSearchText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_search" android:textSize="10sp" android:textColor="@color/text_dark_hint"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navDeals"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navDealsIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_orders" app:tint="@color/text_dark_hint"/>
            <TextView android:id="@+id/navDealsText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_orders" android:textSize="10sp" android:textColor="@color/text_dark_hint"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navProfileIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_profile" app:tint="@color/nb_primary"/>
            <TextView android:id="@+id/navProfileText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textSize="10sp" android:textColor="@color/nb_primary" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

