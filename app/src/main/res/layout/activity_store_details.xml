<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".Store_Details">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_header"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="@drawable/bg_icon_circle_white"
                android:padding="8dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Store Details"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- STORE HERO (no rating stars) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_header"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="@drawable/bg_store_image_circle"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏪"
                            android:textSize="44sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_store_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FreshMart Grocery"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- QUICK STATS (Active Deals + Distance only – no Rating chip) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:elevation="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_chip_white"
                        android:padding="10dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center_horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="#E03B2F"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Deals"
                            android:textColor="#9AA0AC"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_chip_white"
                        android:padding="10dp"
                        android:gravity="center_horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.2km"
                            android:textColor="#27AE60"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distance"
                            android:textColor="#9AA0AC"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- MAIN CONTENT CARDS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- STORE INFO CARD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_order_card"
                        android:padding="16dp"
                        android:elevation="4dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STORE INFO"
                            android:textColor="#9AA0AC"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="14dp" />

                        <!-- Location row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <LinearLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle_blue"
                                android:gravity="center"
                                android:layout_marginEnd="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="📍" android:textSize="16sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Location" android:textColor="#9AA0AC" android:textSize="10sp" />
                                <TextView android:id="@+id/tv_location"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="No. 45, Galle Road, Colombo 03"
                                    android:textColor="#1B2D4F" android:textSize="13sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="#F0F0F0" android:layout_marginBottom="12dp" />

                        <!-- Contact row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <LinearLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle_blue"
                                android:gravity="center"
                                android:layout_marginEnd="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="📞" android:textSize="16sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Contact" android:textColor="#9AA0AC" android:textSize="10sp" />
                                <TextView android:id="@+id/tv_contact"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="+94 11 234 5678"
                                    android:textColor="#1B2D4F" android:textSize="13sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="#F0F0F0" android:layout_marginBottom="12dp" />

                        <!-- Opening Hours row (no "Open" badge) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_circle_blue"
                                android:gravity="center"
                                android:layout_marginEnd="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="🕐" android:textSize="16sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Opening Hours" android:textColor="#9AA0AC" android:textSize="10sp" />
                                <TextView android:id="@+id/tv_hours"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="7:00 AM – 10:00 PM Daily"
                                    android:textColor="#1B2D4F" android:textSize="13sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- PRODUCTS CARD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_order_card"
                        android:padding="16dp"
                        android:elevation="4dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OUR PRODUCTS"
                            android:textColor="#9AA0AC"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="10dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvStoreProducts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"/>
                    </LinearLayout>

                    <!-- AVAILABLE DEALS CARD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_order_card"
                        android:padding="16dp"
                        android:elevation="4dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AVAILABLE DEALS"
                            android:textColor="#9AA0AC"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="10dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvStoreDeals"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"/>
                    </LinearLayout>

                    <!-- PROMOTIONS CARD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_order_card"
                        android:padding="16dp"
                        android:elevation="4dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PROMOTIONS"
                            android:textColor="#9AA0AC"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="10dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvStorePromos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- BOTTOM ACTION BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:elevation="16dp">

            <LinearLayout
                android:id="@+id/btn_call_store"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_cancel_btn"
                android:layout_marginEnd="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📞  " android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Call" android:textColor="#E03B2F" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_view_deals"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_tab_active">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏷  " android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="View All Deals" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

