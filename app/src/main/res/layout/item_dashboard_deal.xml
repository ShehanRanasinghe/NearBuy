<?xml version="1.0" encoding="utf-8"?>
<!--
    item_dashboard_deal.xml
    Compact horizontal card used in the "Latest Deals" RecyclerView on the Dashboard.
    Flat structure (2 levels) to minimise ViewRootImpl.performTraversals() cost.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="130dp"
    android:orientation="vertical"
    android:background="@drawable/bg_deal_card"
    android:padding="16dp"
    android:layout_marginEnd="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Emoji badge row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">
        <TextView
            android:id="@+id/tvDealEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="18sp"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/tvDealDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50% OFF"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvDealTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fresh Apples"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tvDealShopDist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FreshMart · 0.8 km"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="8dp"
        android:maxLines="1"
        android:ellipsize="end"/>

</LinearLayout>

