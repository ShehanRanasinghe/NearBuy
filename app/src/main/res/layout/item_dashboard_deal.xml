<?xml version="1.0" encoding="utf-8"?>
<!--
    item_dashboard_deal.xml
    Compact horizontal card used in the "Latest Deals" RecyclerView on the Dashboard.
    Shows deal title, shop name, short description preview, and discount badge.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="210dp"
    android:layout_height="160dp"
    android:orientation="vertical"
    android:background="@drawable/bg_deal_card"
    android:padding="14dp"
    android:layout_marginEnd="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Emoji badge row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">
        <TextView
            android:id="@+id/tvDealEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="16sp"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/tvDealDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50% OFF"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvDealTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fresh Apples"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tvDealDescription"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Farm fresh apples sourced daily from local farms"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="4dp"
        android:maxLines="2"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tvDealShopDist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FreshMart · 0.8 km"
        android:textColor="#B3FFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:ellipsize="end"/>

</LinearLayout>

