<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light_grey">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_topbar_curved"
        android:paddingStart="16dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_icon_circle_white"
            android:padding="8dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Orders"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your purchase history"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- LIFETIME STATS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_stat_card"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIFETIME STATS"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.10"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Total Orders -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_metric_box_rounded"
                android:padding="8dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:id="@+id/tvTotalOrdersStat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orders"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Total Spent -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_metric_box_rounded"
                android:padding="8dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:id="@+id/tvTotalSpentStat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs.4,250"
                    android:textColor="@color/nb_accent_light"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Spent"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Delivered -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_metric_box_rounded"
                android:padding="8dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:id="@+id/tvDeliveredStat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9"
                    android:textColor="@color/stat_green"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivered"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Avg Order -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_metric_box_rounded"
                android:padding="8dp">
                <TextView
                    android:id="@+id/tvAvgOrderStat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs.354"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avg. Order"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- FILTER TABS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/bg_white"
        android:elevation="1dp">
        <LinearLayout
            android:id="@+id/filterTabs"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView android:id="@+id/tabAll"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="All" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                android:gravity="center" android:paddingStart="18dp" android:paddingEnd="18dp"
                android:background="@drawable/bg_distance_chip_active" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tabDelivered"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="Delivered" android:textColor="@color/nb_primary" android:textSize="13sp"
                android:gravity="center" android:paddingStart="18dp" android:paddingEnd="18dp"
                android:background="@drawable/bg_distance_chip" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tabProcessing"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="Processing" android:textColor="@color/nb_primary" android:textSize="13sp"
                android:gravity="center" android:paddingStart="18dp" android:paddingEnd="18dp"
                android:background="@drawable/bg_distance_chip" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/tabCancelled"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="Cancelled" android:textColor="@color/nb_primary" android:textSize="13sp"
                android:gravity="center" android:paddingStart="18dp" android:paddingEnd="18dp"
                android:background="@drawable/bg_distance_chip"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Result count -->
    <TextView
        android:id="@+id/tvResultCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="12 orders"
        android:textColor="@color/text_dark_secondary"
        android:textSize="13sp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp"/>

    <!-- Empty state (shown when no orders are available) -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦"
            android:textSize="48sp"
            android:layout_marginBottom="16dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No orders yet"
            android:textColor="@color/text_dark_secondary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Orders List -->
    <ListView
        android:id="@+id/listOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="72dp"
        android:clipToPadding="false"/>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav_bar"
        android:elevation="12dp"
        android:baselineAligned="false">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navHomeIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_home" app:tint="@color/text_dark_hint"/>
            <TextView android:id="@+id/navHomeText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textSize="10sp" android:textColor="@color/text_dark_hint"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navSearch"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navSearchIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_search" app:tint="@color/text_dark_hint"/>
            <TextView android:id="@+id/navSearchText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_search" android:textSize="10sp" android:textColor="@color/text_dark_hint"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navDeals"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navDealsIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_orders" app:tint="@color/nb_primary"/>
            <TextView android:id="@+id/navDealsText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_orders" android:textSize="10sp" android:textColor="@color/nb_primary" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/navProfileIcon"
                android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_profile" app:tint="@color/text_dark_hint"/>
            <TextView android:id="@+id/navProfileText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textSize="10sp" android:textColor="@color/text_dark_hint"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

