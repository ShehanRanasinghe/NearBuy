<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_white"
    android:padding="16dp"
    android:layout_marginBottom="16dp"
    android:elevation="3dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Top row: emoji + shop info + status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Shop emoji circle -->
        <LinearLayout
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:gravity="center"
            android:background="@drawable/bg_icon_circle_teal"
            android:layout_marginEnd="14dp">
            <TextView
                android:id="@+id/tvOrderShopEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏪"
                android:textSize="26sp"/>
        </LinearLayout>

        <!-- Order info column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvOrderShopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FreshMart Grocery"
                android:textColor="@color/text_dark_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#ORD-2024-001"
                android:textColor="@color/nb_primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="March 25, 2026"
                android:textColor="@color/text_dark_hint"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delivered"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/bg_status_delivered"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp"/>

    <!-- Bottom row: items summary + count + total -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Items info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvOrderItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fresh Apples x2, Milk x1"
                android:textColor="@color/text_dark_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvOrderItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 items"
                    android:textColor="@color/text_dark_hint"
                    android:textSize="11sp"/>

                <!-- Fulfillment type badge (Delivery / Pick Up) -->
                <TextView
                    android:id="@+id/tvOrderFulfillment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivery"
                    android:textSize="10sp"
                    android:textColor="@color/nb_primary"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_distance_chip"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Total amount -->
        <TextView
            android:id="@+id/tvOrderTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rs.350"
            android:textColor="@color/nb_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>

