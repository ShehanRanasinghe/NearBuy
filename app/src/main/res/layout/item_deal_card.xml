<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_white"
    android:padding="16dp"
    android:layout_marginBottom="10dp"
    android:elevation="3dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Top row: emoji + info + discount badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Product emoji circle -->
        <LinearLayout
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:gravity="center"
            android:background="@drawable/bg_icon_circle_teal"
            android:layout_marginEnd="14dp">
            <TextView
                android:id="@+id/tvDealEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍎"
                android:textSize="30sp"/>
        </LinearLayout>

        <!-- Deal info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDealTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fresh Red Apples"
                android:textColor="@color/text_dark_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvDealShop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FreshMart Grocery"
                android:textColor="@color/text_dark_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <!-- Distance + Category row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvDealDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.8 km"
                    android:textColor="@color/nb_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_distance_badge"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvDealCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fruits"
                    android:textColor="@color/text_dark_hint"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Discount badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvDealDiscount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50% OFF"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="@drawable/bg_discount_badge"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp"/>

    <!-- Bottom: price row + expiry -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Expiry label -->
        <TextView
            android:id="@+id/tvDealExpiry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏱ Expires in 3 days"
            android:textColor="@color/text_dark_hint"
            android:textSize="11sp"/>

        <!-- Prices -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDealOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs.200"
                android:textColor="@color/text_dark_hint"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvDealPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs.120"
                android:textColor="@color/nb_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

