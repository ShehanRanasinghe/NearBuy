<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <!-- Decorative circle top-right -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/circle_accent"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Decorative circle bottom-left -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_accent"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="-40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Decorative circle bottom-right -->
    <View
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:background="@drawable/circle_accent"
        android:layout_marginBottom="110dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Center group -->
    <LinearLayout
        android:id="@+id/centerGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo art with glow rings -->
        <FrameLayout
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center">

            <View android:layout_width="210dp" android:layout_height="210dp"
                android:background="@drawable/bg_logo_ring_outer" android:layout_gravity="center"/>
            <View android:layout_width="168dp" android:layout_height="168dp"
                android:background="@drawable/bg_logo_ring_mid" android:layout_gravity="center"/>
            <View android:layout_width="130dp" android:layout_height="130dp"
                android:background="@drawable/bg_logo_circle" android:layout_gravity="center"/>

            <!-- Sparkle dots -->
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/dot_orange" android:layout_gravity="top|start"
                android:layout_marginTop="28dp" android:layout_marginStart="30dp"/>
            <View android:layout_width="6dp" android:layout_height="6dp"
                android:background="@drawable/dot_teal" android:layout_gravity="top|end"
                android:layout_marginTop="38dp" android:layout_marginEnd="26dp"/>
            <View android:layout_width="6dp" android:layout_height="6dp"
                android:background="@drawable/dot_teal" android:layout_gravity="bottom|start"
                android:layout_marginBottom="36dp" android:layout_marginStart="24dp"/>
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/dot_orange" android:layout_gravity="bottom|end"
                android:layout_marginBottom="30dp" android:layout_marginEnd="28dp"/>

            <!-- Logo image -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/nearbuy_logo"
                android:contentDescription="@string/logo_desc"
                android:layout_gravity="center"
                android:scaleType="fitCenter"/>
        </FrameLayout>

        <!-- App name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NearBuy"
            android:textColor="@color/white"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_marginTop="20dp"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_tagline"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="15sp"
            android:layout_marginTop="8dp"/>

        <!-- Orange accent bar -->
        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="@drawable/btn_orange"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

    <!-- Loading indicator pinned near the bottom -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminateTint="@color/nb_accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="72dp" />

    <!-- Version text at bottom -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_version"
        android:textColor="@color/text_on_dark_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

