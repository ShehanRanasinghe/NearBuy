<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.NearBuy" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Theme for the Categories screen – blue-green, no default action bar -->
    <style name="Theme.NearBuy.Categories" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cat_toolbar</item>
        <item name="colorPrimaryVariant">@color/cat_toolbar_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/cat_icon_tint</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/cat_toolbar_dark</item>
    </style>

    <!-- Shared NearBuy screen theme – no default action bar -->
    <style name="Theme.NearBuy.Screen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/nb_teal</item>
        <item name="colorPrimaryVariant">@color/nb_teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/nb_orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/nb_teal_dark</item>
    </style>
</resources>