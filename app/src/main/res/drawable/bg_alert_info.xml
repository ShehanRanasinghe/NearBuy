<?xml version="1.0" encoding="utf-8"?>
<!-- Security / info tip box: subtle orange-tinted background with a matching border.
     Used on the OTP screen to display the "never share your code" warning. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1AFF6D00" />   <!-- 10 % orange fill  -->
    <stroke android:width="1dp" android:color="#40FF6D00" />   <!-- 25 % orange border -->
    <corners android:radius="8dp" />
</shape>

