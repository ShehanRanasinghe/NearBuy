<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NearBuy"
        tools:targetApi="31">

        <!-- ── SPLASH SCREEN – Main launcher ── -->
        <activity
            android:name=".app.startup.SplashScreen"
            android:exported="true"
            android:theme="@style/Theme.NearBuy.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── WELCOME ── -->
        <activity
            android:name=".app.startup.WelcomeActivity"
            android:exported="false"
            android:theme="@style/Theme.NearBuy.Auth"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── AUTH ── -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.NearBuy.Auth"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.NearBuy.Auth"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".auth.OTPVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.NearBuy.Auth"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".auth.ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.NearBuy.Auth"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── DASHBOARD ── -->
        <activity
            android:name=".dashboard.DashboardActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── SEARCH ── -->
        <activity
            android:name=".search.SearchActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />

        <!-- ── DEALS ── -->
        <activity
            android:name=".discounts.DealsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── PROFILE ── -->
        <activity
            android:name=".profile.ProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── NOTIFICATIONS ── -->
        <activity
            android:name=".notifications.NotificationsActivity"
            android:exported="false"
            android:theme="@style/Theme.NearBuy.Screen"
            android:label="@string/notif_screen_title" />

        <!-- ── CATEGORIES ── -->
        <activity
            android:name=".categories.CategoriesActivity"
            android:exported="true"
            android:theme="@style/Theme.NearBuy.Categories"
            android:label="@string/categories_title" />

        <!-- ── ORDERS ── -->
        <activity
            android:name=".orders.OrdersActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── PRODUCT DETAILS ── -->
        <activity
            android:name=".product.ProductDetailsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── STORE DETAILS ── -->
        <activity
            android:name=".store.StoreDetailsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── DEAL DETAILS ── -->
        <activity
            android:name=".discounts.DealDetailsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── SAVED DEALS ── -->
        <activity
            android:name=".discounts.SavedDealsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── SETTINGS ── -->
        <activity
            android:name=".profile.SettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── DEALS AND PROMO (full list, accessed via View All only) ── -->
        <activity
            android:name=".discounts.DealsAndPromoActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── LOGOUT ── -->
        <activity
            android:name=".profile.LogoutActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>